{
 "extends": [
  "config:recommended"
 ],
 "baseBranchPatterns": [
  "main"
 ],
 "packageRules": [
  {
   "matchUpdateTypes": [
    "minor",
    "patch",
    "pin",
    "digest"
   ],
   "automerge": true,
   "groupName": "all non-major dependencies",
   "groupSlug": "all-minor-patch",
   "matchPackageNames": [
    "*"
   ]
  }
 ]
}
